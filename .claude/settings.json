{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const i=JSON.parse(d);const f=(i.tool_input||{}).file_path||(i.tool_response||{}).filePath||'';if(f&&/\\.ts$/.test(f)){require('child_process').execSync('npx prettier --write '+JSON.stringify(f),{stdio:'inherit'});}});\"",
            "timeout": 30,
            "statusMessage": "Formatting with Prettier..."
          }
        ]
      }
    ]
  }
}
