model Research {
  id                     String                @id @default(uuid())
  title                  String
  type                   Int
  status                 ProjectStatus         @default(DRAFT)
  userId                 String                @map("user_id")
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  algorithmId            Int?                  @unique @map("algorithm_id")
  algorithmDeltaId       Int?                  @unique @map("algorithm_delta_id")
  algorithmPropagationId Int?                  @unique @map("algorithm_propagation_id")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  algorithm              Algorithm?            @relation(fields: [algorithmId], references: [id])
  algorithmDelta         AlgorithmDelta?       @relation(fields: [algorithmDeltaId], references: [id])
  algorithmPropagation   AlgorithmPropagation? @relation(fields: [algorithmPropagationId], references: [id])
  activities             Activity[]

  @@index([userId, status])
  @@index([userId, type])
  @@map("research")
}
