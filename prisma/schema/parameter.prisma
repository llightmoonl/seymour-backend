model Parameter {
  id        Int @id @default(autoincrement())
  value     Float

  typeId    Int
  type      ParameterType @relation(fields: [typeId], references: [id])

  algorithmId Int
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id])

  @@map("parameter")
}

model ParameterType {
  id         Int @id @default(autoincrement())
  type       String
  parameters Parameter[]

  @@map("parameterType")
}
