model Algorithm {
  id       Int       @id @default(autoincrement())
  data     Json?
  w        Json
  i        Int
  j        Int
  y_pred   Int
  s        Int
  correction String?
  neuron   Int
  epoch    Int
  error    Int
  isTrained Boolean
  research Research?

  @@map("algorithm")
}

model AlgorithmDelta {
  id        Int      @id @default(autoincrement())
  data      Json?
  w         Json
  i         Int
  j         Int
  k         Int
  y_pred    Json
  s         Json
  epsilon   Json
  eta       Float
  epoch     Int
  error     Int
  isTrained Boolean
  research  Research?

  @@map("algorithm_delta")
}
